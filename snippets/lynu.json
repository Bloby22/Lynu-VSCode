{
  "Variable (immutable)": {
    "prefix": "set",
    "body": ["set ${1:name} = ${2:value}"],
    "description": "Declare an immutable variable"
  },
  "Variable (mutable)": {
    "prefix": "let",
    "body": ["let ${1:name} = ${2:value}"],
    "description": "Declare a mutable variable"
  },
  "Variable with type": {
    "prefix": "settype",
    "body": ["set ${1:name}: ${2|num,text,bool|} = ${3:value}"],
    "description": "Declare a typed immutable variable"
  },
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:param}: ${3|num,text,bool|}) -> ${4|num,text,bool,void|} do",
      "\t${5:give ${6:result}}",
      "end"
    ],
    "description": "Define a function"
  },
  "Function void": {
    "prefix": "fnvoid",
    "body": [
      "fn ${1:name}(${2:param}: ${3|num,text,bool|}) do",
      "\t$0",
      "end"
    ],
    "description": "Define a void function"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} then",
      "\t$0",
      "end"
    ],
    "description": "If statement"
  },
  "If/Else statement": {
    "prefix": "ifelse",
    "body": [
      "if ${1:condition} then",
      "\t${2:-- true branch}",
      "else",
      "\t${3:-- false branch}",
      "end"
    ],
    "description": "If/Else statement"
  },
  "If/Else if/Else": {
    "prefix": "ifelseif",
    "body": [
      "if ${1:condition1} then",
      "\t${2:-- branch 1}",
      "else if ${3:condition2} then",
      "\t${4:-- branch 2}",
      "else",
      "\t${5:-- fallback}",
      "end"
    ],
    "description": "If / Else if / Else chain"
  },
  "Loop (infinite)": {
    "prefix": "loop",
    "body": [
      "loop do",
      "\t${1:-- body}",
      "\tif ${2:condition} then",
      "\t\tbreak",
      "\tend",
      "end"
    ],
    "description": "Infinite loop with break"
  },
  "Repeat N times": {
    "prefix": "repeat",
    "body": [
      "repeat ${1:n} times do",
      "\t$0",
      "end"
    ],
    "description": "Repeat N times"
  },
  "Repeat N times with index": {
    "prefix": "repeatas",
    "body": [
      "repeat ${1:n} times as ${2:i} do",
      "\t$0",
      "end"
    ],
    "description": "Repeat N times with index variable"
  },
  "Say (println)": {
    "prefix": "say",
    "body": ["say ${1:\"hello\"}"],
    "description": "Print to output with newline"
  },
  "Give (return)": {
    "prefix": "give",
    "body": ["give ${1:value}"],
    "description": "Return a value from a function"
  },
  "Use module": {
    "prefix": "use",
    "body": ["use \"${1|math,random|}\""],
    "description": "Import a built-in module"
  },
  "Array literal": {
    "prefix": "arr",
    "body": ["let ${1:arr} = [${2:10, 20, 30}]"],
    "description": "Declare an array"
  },
  "Object literal": {
    "prefix": "obj",
    "body": [
      "let ${1:obj} = { ${2:key}: ${3:value} }"
    ],
    "description": "Declare an object"
  },
  "Array push": {
    "prefix": "push",
    "body": ["${1:arr}.push(${2:value})"],
    "description": "Push value to array"
  },
  "Array pop": {
    "prefix": "pop",
    "body": ["${1:arr}.pop()"],
    "description": "Pop value from array"
  },
  "textof()": {
    "prefix": "textof",
    "body": ["textof(${1:value})"],
    "description": "Convert value to text"
  },
  "numof()": {
    "prefix": "numof",
    "body": ["numof(${1:value})"],
    "description": "Convert value to num"
  },
  "size()": {
    "prefix": "size",
    "body": ["size(${1:value})"],
    "description": "Get size of text or array"
  },
  "input()": {
    "prefix": "input",
    "body": ["input(${1:\"Prompt: \"})"],
    "description": "Read user input"
  },
  "Math module usage": {
    "prefix": "usemath",
    "body": [
      "use \"math\"",
      "say \"PI = \" + textof(math.PI)",
      "say \"sqrt(${1:16}) = \" + textof(math_sqrt(${1:16}))"
    ],
    "description": "Import and use math module"
  },
  "Block comment": {
    "prefix": "---",
    "body": [
      "---",
      "${1:comment}",
      "---"
    ],
    "description": "Block comment"
  },
  "Hello World": {
    "prefix": "hello",
    "body": [
      "-- Hello World",
      "say \"Ahoj ze světa Lynu!\""
    ],
    "description": "Hello World program"
  },
  "Factorial function": {
    "prefix": "factorial",
    "body": [
      "fn faktorial(n: num) -> num do",
      "\tif n below 2 then",
      "\t\tgive 1",
      "\tend",
      "\tgive n * faktorial(n - 1)",
      "end"
    ],
    "description": "Recursive factorial function"
  }
}
