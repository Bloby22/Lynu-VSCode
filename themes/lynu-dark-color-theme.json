{
  "name": "Lynu Dark",
  "$schema": "vscode://schemas/color-theme",
  "type": "dark",
  "colors": {
    "editor.background": "#0f1117",
    "editor.foreground": "#d4d4d4",
    "editor.lineHighlightBackground": "#1a1d27",
    "editor.selectionBackground": "#264f78",
    "editorLineNumber.foreground": "#404050",
    "editorLineNumber.activeForeground": "#7c7fa0",
    "editorCursor.foreground": "#a78bfa",
    "editorBracketMatch.background": "#2a2040",
    "editorBracketMatch.border": "#7c3aed"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment.line.double-dash.lynu", "comment.block.lynu"],
      "settings": { "foreground": "#5c6370", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": "string.quoted.double.lynu",
      "settings": { "foreground": "#98c379" }
    },
    {
      "name": "String escape sequences",
      "scope": "constant.character.escape.lynu",
      "settings": { "foreground": "#56b6c2" }
    },
    {
      "name": "Numbers",
      "scope": "constant.numeric.lynu",
      "settings": { "foreground": "#d19a66" }
    },
    {
      "name": "Boolean literals",
      "scope": "constant.language.boolean.lynu",
      "settings": { "foreground": "#56b6c2", "fontStyle": "italic" }
    },
    {
      "name": "Storage / Declaration keywords (set, let, fn)",
      "scope": "storage.type.lynu",
      "settings": { "foreground": "#c678dd", "fontStyle": "bold" }
    },
    {
      "name": "Control flow keywords",
      "scope": "keyword.control.lynu",
      "settings": { "foreground": "#e06c75" }
    },
    {
      "name": "IO keywords (say, print)",
      "scope": "keyword.other.io.lynu",
      "settings": { "foreground": "#61afef", "fontStyle": "bold" }
    },
    {
      "name": "Module keyword (use)",
      "scope": "keyword.control.import.lynu",
      "settings": { "foreground": "#c678dd" }
    },
    {
      "name": "Word operators (is, isnt, above, and, or...)",
      "scope": "keyword.operator.word.lynu",
      "settings": { "foreground": "#e5c07b" }
    },
    {
      "name": "Type names (num, text, bool, void)",
      "scope": "support.type.lynu",
      "settings": { "foreground": "#56b6c2", "fontStyle": "italic" }
    },
    {
      "name": "Function definition name",
      "scope": "entity.name.function.lynu",
      "settings": { "foreground": "#61afef", "fontStyle": "bold" }
    },
    {
      "name": "Function call",
      "scope": "entity.name.function.call.lynu",
      "settings": { "foreground": "#61afef" }
    },
    {
      "name": "Method call",
      "scope": "entity.name.function.member.lynu",
      "settings": { "foreground": "#56b6c2" }
    },
    {
      "name": "Built-in functions",
      "scope": "support.function.builtin.lynu",
      "settings": { "foreground": "#e5c07b", "fontStyle": "italic" }
    },
    {
      "name": "Member access (.field)",
      "scope": "variable.other.member.lynu",
      "settings": { "foreground": "#abb2bf" }
    },
    {
      "name": "Arithmetic operators",
      "scope": "keyword.operator.arithmetic.lynu",
      "settings": { "foreground": "#abb2bf" }
    },
    {
      "name": "Comparison operators",
      "scope": "keyword.operator.comparison.lynu",
      "settings": { "foreground": "#e5c07b" }
    },
    {
      "name": "Assignment operator",
      "scope": "keyword.operator.assignment.lynu",
      "settings": { "foreground": "#abb2bf" }
    },
    {
      "name": "Arrow (->)",
      "scope": "keyword.operator.arrow.lynu",
      "settings": { "foreground": "#c678dd" }
    },
    {
      "name": "Punctuation — parens",
      "scope": "punctuation.definition.parameters.lynu",
      "settings": { "foreground": "#abb2bf" }
    },
    {
      "name": "Punctuation — brackets",
      "scope": "punctuation.definition.array.lynu",
      "settings": { "foreground": "#abb2bf" }
    },
    {
      "name": "Punctuation — braces",
      "scope": "punctuation.definition.object.lynu",
      "settings": { "foreground": "#abb2bf" }
    },
    {
      "name": "Colon",
      "scope": "punctuation.separator.colon.lynu",
      "settings": { "foreground": "#abb2bf" }
    },
    {
      "name": "Variables / identifiers",
      "scope": "variable.other.lynu",
      "settings": { "foreground": "#e06c75" }
    }
  ]
}
